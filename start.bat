@echo off
title Запуск системи Розумний Гуртожиток
chcp 65001 > nul

echo ===================================================
echo   ЗАПУСК СИСТЕМИ "РОЗУМНИЙ ГУРТОЖИТОК" (MVP)
echo ===================================================

:: 1. Перевірка та спроба запуску служби MySQL
echo [1/3] Перевірка бази даних...
net start MySQL80 >nul 2>&1
if %errorlevel% neq 0 (
    echo Попередження: Служба MySQL вже працює або потребує ручного запуску.
) else (
    echo Служба MySQL успішно активована.
)

:: 2. Запуск сервера Node.js у новому вікні
echo [2/3] Запуск сервера додатку...
start "NodeJS Server" cmd /c "npm start"

:: 3. Затримка для ініціалізації сервера та відкриття сайту
echo [3/3] Відкриття інтерфейсу користувача...
timeout /t 3 > nul
start http://localhost:3000

echo.
echo ===================================================
echo СИСТЕМА ПРАЦЮЄ. НЕ ЗАКРИВАЙТЕ ВІКНО СЕРВЕРА!
echo ===================================================
pause